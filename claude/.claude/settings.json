{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read(**)",
      "TodoRead",
      "TodoWrite(**)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git --no-pager diff:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git config --get:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(less:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(tree:*)",
      "Bash(pwd:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(cut:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(jq:*)",
      "Bash(yq eval:*)",
      "Bash(pnpm list:*)",
      "Bash(man:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(echo:*)"
    ],
    "deny": [
      "Read(**/.ssh/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials.json)",
      "Edit(**/.ssh/**)",
      "Edit(//etc/**)",
      "Edit(//usr/**)",
      "Edit(//System/**)",
      "Bash(su:*)",
      "Bash(sudo:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(passwd:*)",
      "Bash(history:*)",
      "Bash(git push:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",
      "EnterPlanMode",
      "ExitPlanMode",
      "DesignSync",
      "NotebookEdit",
      "SendMessage",
      "PushNotification",
      "RemoteTrigger",
      "ReportFindings",
      "ScheduleWakeup",
      "AskUserQuestion",
      "CronCreate",
      "CronDelete",
      "CronList"
    ]
  },
  "disableClaudeAiConnectors": true,
  "skillOverrides": {
    "dataviz": "off",
    "claude-api": "off",
    "schedule": "off",
    "run": "off"
  },
  "hooks": {
    "Stop": [],
    "Notification": []
  },
  "disableRemoteControl": true,
  "disableWorkflows": true,
  "disableArtifact": true,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-wrapper.sh"
  },
  "effortLevel": "high",
  "promptSuggestionEnabled": false,
  "awaySummaryEnabled": false,
  "theme": "auto",
  "preferredNotifChannel": "auto",
  "switchModelsOnFlag": false,
  "fileCheckpointingEnabled": false,
  "skipAutoPermissionPrompt": true
}
