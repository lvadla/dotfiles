prefix_rule(
    pattern = ["git", "push"],
    decision = "forbidden",
    justification = "All git push commands are disabled; only the user can invoke these",
    match = [
        "git push",
        "git push --force",
        "git push --force-with-lease origin main",
        "git push origin +HEAD:main",
    ],
    not_match = [
        "git pull",
        "git commit",
    ],
)
